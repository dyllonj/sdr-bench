{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/policy_episode.schema.json",
  "title": "Policy Episode",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "windows"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "windows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "evaluation_window.schema.json"
      }
    }
  }
}
