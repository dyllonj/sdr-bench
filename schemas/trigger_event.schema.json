{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/trigger_event.schema.json",
  "title": "Trigger Event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "account_id",
    "event_ts",
    "event_type",
    "source_type",
    "confidence",
    "recency_days",
    "evidence_refs"
  ],
  "properties": {
    "event_id": {
      "type": "string",
      "minLength": 1
    },
    "account_id": {
      "type": "string",
      "minLength": 1
    },
    "event_ts": {
      "type": "string",
      "format": "date-time"
    },
    "event_type": {
      "type": "string",
      "minLength": 1
    },
    "source_type": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "recency_days": {
      "type": "integer",
      "minimum": 0
    },
    "evidence_refs": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string"}
    }
  }
}
