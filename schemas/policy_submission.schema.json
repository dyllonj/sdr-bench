{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/policy_submission.schema.json",
  "title": "Policy Submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "submissions"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "submissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "model_output.schema.json"
      }
    }
  }
}
