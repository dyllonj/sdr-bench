{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/hidden_labels.schema.json",
  "title": "Hidden Labels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "window_id",
    "account_outcomes"
  ],
  "properties": {
    "window_id": {
      "type": "string",
      "minLength": 1
    },
    "account_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "account_id",
          "potential_outcomes"
        ],
        "properties": {
          "account_id": {
            "type": "string",
            "minLength": 1
          },
          "potential_outcomes": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "human_touch",
              "automated_outbound",
              "nurture",
              "recycle",
              "disqualify",
              "wait"
            ],
            "properties": {
              "human_touch": {
                "$ref": "#/$defs/actionOutcome"
              },
              "automated_outbound": {
                "$ref": "#/$defs/actionOutcome"
              },
              "nurture": {
                "$ref": "#/$defs/actionOutcome"
              },
              "recycle": {
                "$ref": "#/$defs/actionOutcome"
              },
              "disqualify": {
                "$ref": "#/$defs/actionOutcome"
              },
              "wait": {
                "$ref": "#/$defs/actionOutcome"
              }
            }
          }
        }
      }
    },
    "contact_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "account_id",
          "default_contact_id",
          "contacts"
        ],
        "properties": {
          "account_id": {
            "type": "string",
            "minLength": 1
          },
          "default_contact_id": {
            "type": "string",
            "minLength": 1
          },
          "contacts": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "contact_id",
                "meeting_gain",
                "opp_gain",
                "pipeline_gain"
              ],
              "properties": {
                "contact_id": {
                  "type": "string",
                  "minLength": 1
                },
                "meeting_gain": {
                  "type": "number",
                  "minimum": 0
                },
                "opp_gain": {
                  "type": "number",
                  "minimum": 0
                },
                "pipeline_gain": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    },
    "trigger_outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "account_id",
          "triggers"
        ],
        "properties": {
          "account_id": {
            "type": "string",
            "minLength": 1
          },
          "triggers": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "event_id",
                "relevance_gain"
              ],
              "properties": {
                "event_id": {
                  "type": "string",
                  "minLength": 1
                },
                "relevance_gain": {
                  "type": "number",
                  "minimum": 0
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "actionOutcome": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meeting_prob",
        "opp_prob",
        "pipeline_value"
      ],
      "properties": {
        "meeting_prob": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "opp_prob": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "pipeline_value": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
