{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json",
  "title": "Policy Episode Labels",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "episode_id",
    "windows"
  ],
  "properties": {
    "episode_id": {
      "type": "string",
      "minLength": 1
    },
    "windows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "window_id",
          "labels",
          "policy_transitions"
        ],
        "properties": {
          "window_id": {
            "type": "string",
            "minLength": 1
          },
          "labels": {
            "$ref": "hidden_labels.schema.json"
          },
          "policy_transitions": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "account_id",
                "actions"
              ],
              "properties": {
                "account_id": {
                  "type": "string",
                  "minLength": 1
                },
                "actions": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "human_touch",
                    "automated_outbound",
                    "nurture",
                    "recycle",
                    "disqualify",
                    "wait"
                  ],
                  "properties": {
                    "human_touch": {
                      "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/policyTransition"
                    },
                    "automated_outbound": {
                      "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/policyTransition"
                    },
                    "nurture": {
                      "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/policyTransition"
                    },
                    "recycle": {
                      "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/policyTransition"
                    },
                    "disqualify": {
                      "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/policyTransition"
                    },
                    "wait": {
                      "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/policyTransition"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "policyTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cooldown_weeks",
        "remove_from_episode"
      ],
      "properties": {
        "cooldown_weeks": {
          "type": "integer",
          "minimum": 0
        },
        "remove_from_episode": {
          "type": "boolean"
        },
        "next_window_outcome_modifiers": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifierMap"
        }
      }
    },
    "actionOutcomeModifierMap": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "human_touch": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifier"
        },
        "automated_outbound": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifier"
        },
        "nurture": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifier"
        },
        "recycle": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifier"
        },
        "disqualify": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifier"
        },
        "wait": {
          "$ref": "https://sdr-bench.dev/schemas/policy_episode_labels.schema.json#/$defs/actionOutcomeModifier"
        }
      }
    },
    "actionOutcomeModifier": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "meeting_prob_multiplier",
        "opp_prob_multiplier",
        "pipeline_value_multiplier"
      ],
      "properties": {
        "meeting_prob_multiplier": {
          "type": "number",
          "minimum": 0
        },
        "opp_prob_multiplier": {
          "type": "number",
          "minimum": 0
        },
        "pipeline_value_multiplier": {
          "type": "number",
          "minimum": 0
        }
      }
    }
  }
}
