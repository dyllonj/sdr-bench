{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/rationale_codes.schema.json",
  "title": "SDR Bench Rationale Code Dictionary",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "why_account_codes",
    "why_now_codes",
    "why_persona_codes",
    "why_channel_codes"
  ],
  "properties": {
    "why_account_codes": {
      "$ref": "#/$defs/codeDictionary"
    },
    "why_now_codes": {
      "$ref": "#/$defs/codeDictionary"
    },
    "why_persona_codes": {
      "$ref": "#/$defs/codeDictionary"
    },
    "why_channel_codes": {
      "$ref": "#/$defs/codeDictionary"
    }
  },
  "$defs": {
    "codeDictionary": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9_]+$"
      },
      "additionalProperties": {
        "$ref": "#/$defs/codeEntry"
      }
    },
    "codeEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "description",
        "allowed_fact_types",
        "allowed_entities"
      ],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "allowed_fact_types": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_:]+$"
          }
        },
        "allowed_entities": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        }
      }
    }
  }
}
