{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdr-bench.dev/schemas/robustness_submission.schema.json",
  "title": "Robustness Suite Submission",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "suite_id",
    "submissions"
  ],
  "properties": {
    "suite_id": {
      "type": "string",
      "minLength": 1
    },
    "submissions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "https://sdr-bench.dev/schemas/robustness_submission.schema.json#/$defs/submission_case"
      }
    }
  },
  "$defs": {
    "submission_case": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "case_id",
        "submission"
      ],
      "properties": {
        "case_id": {
          "type": "string",
          "minLength": 1
        },
        "submission": {
          "$ref": "model_output.schema.json"
        }
      }
    }
  }
}
